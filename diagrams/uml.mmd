classDiagram
    class PetInfo {
        +string species
        +string name
        +string gender
        +date dob
        +string breed
        +string[] healthIssues
        +calculateAge() int
        +updateHealthIssue(issue: string) void
        +getCareSummary() string
    }

    class PetCareTasks {
        +TaskInfo[] tasks
        +addTask(task: TaskInfo) void
        +removeTask(taskId: string) void
        +getTasks() TaskInfo[]
    }

    class Schedule {
        +date scheduleDate
        +TaskInfo[] scheduledTasks
        +string[] availableTimeSlots
        +string[] constraints
        +setAvailability(timeSlots: string[]) void
        +addTask(task: TaskInfo) bool
        +removeTask(taskId: string) void
        +canSchedule(task: TaskInfo, timeSlot: string) bool
        +getSchedule() TaskInfo[]
    }

    class TaskInfo {
        +string taskType
        +string description
        +string priority
        +string preferredTime
        +int durationMinutes
        +string[] preferences
        +setPriority(priority: string) void
        +addPreference(preference: string) void
        +isCompatibleWith(otherTask: TaskInfo) bool
    }

    PetInfo *-- "1" PetCareTasks : has
    PetInfo *-- "1" Schedule : has
    PetCareTasks *-- "*" TaskInfo : contains
    Schedule o-- "*" TaskInfo : schedules
